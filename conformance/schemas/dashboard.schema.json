{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dashboard.json — per-study reconciliation summary",
  "type": "object",
  "required": ["study_id", "total_billed", "total_collected", "outstanding_ar",
               "unbilled_estimate", "exceptions_count"],
  "properties": {
    "study_id": {"type": "string"},
    "site_id": {"type": ["string", "null"]},
    "investigator": {"type": ["string", "null"]},
    "total_billed": {"type": "number"},
    "total_collected": {"type": "number"},
    "outstanding_ar": {"type": "number"},
    "holdback_withheld": {"type": "number"},
    "unbilled_estimate": {"type": "number"},
    "exceptions_count": {"type": "integer"},
    "avg_days_to_payment": {"type": ["number", "null"]}
  }
}
